PORT=5001
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/google-review-platform?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Client URL (for CORS) — set to your Vercel URL in production
# Multiple URLs: CLIENT_URL=https://your-app.vercel.app,https://your-custom-domain.com
CLIENT_URL=http://localhost:5173

# OpenAI
OPENAI_API_KEY=sk-...

# Nodemailer (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Google Review Platform <noreply@yourplatform.com>"

# Multer Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads
